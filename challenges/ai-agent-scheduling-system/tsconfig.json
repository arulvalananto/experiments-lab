{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "outDir": "dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["*.ts", "types/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
