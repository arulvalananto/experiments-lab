{
    "name": "stacksy-auth-service",
    "version": "1.0.0",
    "description": "Authentication service for Stacksy",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "type-check": "tsc --noEmit",
        "lint": "npx eslint src",
        "lint:fix": "npx eslint src --fix",
        "prettier": "npx prettier src --check",
        "prettier:fix": "npx prettier src --check --write",
        "pre-commit": "npm run prettier && npm run lint",
        "pre-commit:fix": "npm run prettier:fix && npm run lint:fix"
    },
    "keywords": [
        "auth",
        "fastify",
        "jwt"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.3.1",
        "fastify": "^5.7.4",
        "jsonwebtoken": "^9.0.3",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
