// Now import the function AFTER the mocks (order matters!)
import { createUser } from =E2=80=98./userService=E2=80=99;
import { knex } from =E2=80=98../lib/database=E2=80=99;
import { sendEmail } from =E2=80=98../lib/email=E2=80=99;

describe(=E2=80=99createUser=E2=80=99, () =3D> {
