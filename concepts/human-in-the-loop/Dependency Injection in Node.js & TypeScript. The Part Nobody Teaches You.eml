=80=99, name: =E2=80=98Test=E2=80=99 });

    expect(user.id).toBe(=E2=80=991=E2=80=99);
    expect(sendEmail).toHaveBeenCalledWith(=E2=80=99test@example.com=E2=80=
=99, =E2=80=98Welcome!=E2=80=99);
