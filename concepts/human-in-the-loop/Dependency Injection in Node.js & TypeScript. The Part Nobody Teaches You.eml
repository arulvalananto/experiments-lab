Problems everywhere:
Path-coupled: rename ../lib/database to ../db/database and the mock breaks =
silently =E2=80=94 the test passes but uses the real module
Import order matters: vi.mock calls are hoisted, but if you get it wrong, d=
ebugging is miserable
Type-unsafe: you=E2=80=99re casting to any because the mock system doesn=E2=
=80=99t know your interfaces
Framework-locked: switch from Vitest to Node=E2=80=99s built-in test runner=
? Rewrite every mock
After: Testing with DI
import { describe, it, expect } from =E2=80=98vitest=E2=80=99;
import { createUserService } from =E2=80=98./userService=E2=80=99;

describe(=E2=80=99createUser=E2=80=99, () =3D> {
  it(=E2=80=99creates a user and sends a welcome email=E2=80=99, async () =
=3D> {
    // Plain objects that satisfy the interface =E2=80=94 no mock framework=
 needed
    const fakeRepo =3D {
      create: async (data: any) =3D> ({ id: =E2=80=981=E2=80=99, email: dat=
a.email }),
    };
    const fakeEmail =3D {
      send: async () =3D> {},
    };
    const fakeLogger =3D {
      info: () =3D> {},
    };

    // Track calls manually if needed (or use vi.fn() =E2=80=94 your choice=
, not a requirement)
    const emailCalls: any[] =3D [];
    fakeEmail.send =3D async (to: string, subject: string) =3D> {
      emailCalls.push({ to, subject });
    };

    const service =3D createUserService(fakeRepo, fakeEmail, fakeLogger);
    const user =3D await service.createUser({ email: =E2=80=98test@example.=
com=E2=80=99, name: =E2=80=98Test=E2=80=99 });

    expect(user.id).toBe(=E2=80=991=E2=80=99);
    expect(emailCalls).toEqual([{ to: =E2=80=98test@example.com=E2=80=99, s=
ubject: =E2=80=98Welcome!=E2=80=99 }]);
  });

  it(=E2=80=99logs user creation=E2=80=99, async () =3D> {
    const logs: string[] =3D [];
    const service =3D createUserService(
      { create: async (data: any) =3D> ({ id: =E2=80=9842=E2=80=99, email: =
data.email }) },
      { send: async () =3D> {} },
      { info: (msg: string) =3D> logs.push(msg) }
    );

    await service.createUser({ email: =E2=80=98test@example.com=E2=80=99, n=
ame: =E2=80=98Test=E2=80=99 });

